# =============================================================
# RAG Evaluation System — Environment Configuration Template
# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# =============================================================


# -------------------------------------------------------------
# LLM PROVIDER
# Choose which AI provider to use for evaluation and RAG app
# Options: azure | groq | grok
# -------------------------------------------------------------
LLM_PROVIDER=azure


# -------------------------------------------------------------
# AZURE OPENAI (Primary — recommended, no rate limits)
# Get from: Azure Portal → Your OpenAI Resource → Keys and Endpoint
# -------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01


# -------------------------------------------------------------
# GROQ (Free tier — has rate limits, good as second judge)
# Get free key at: https://console.groq.com
# -------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant


# -------------------------------------------------------------
# GROK / xAI (Alternative provider)
# -------------------------------------------------------------
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-3


# -------------------------------------------------------------
# TARGET APP — What are we testing?
#
# Option A: Test the local mock RAG app (default)
RAG_APP_URL=http://localhost:8000
#
# Option B: Test a Blueverse agent directly via API
# RAG_APP_URL=blueverse
# -------------------------------------------------------------


# -------------------------------------------------------------
# BLUEVERSE FOUNDRY AGENT
# Only needed when RAG_APP_URL=blueverse
#
# How to get these values:
#   BLUEVERSE_TOKEN_URL   → Blueverse documentation or IT admin
#   BLUEVERSE_CHAT_URL    → Your specific agent's API endpoint
#   BLUEVERSE_CLIENT_ID   → App registration in Blueverse/Azure AD
#   BLUEVERSE_CLIENT_SECRET → App registration secret
#
# Authentication flow:
#   Step 1: POST to TOKEN_URL with client_id + client_secret
#           → receive access_token
#   Step 2: POST question to CHAT_URL with Bearer token
#           → receive answer from Blueverse agent
# -------------------------------------------------------------
BLUEVERSE_TOKEN_URL=https://your-token-endpoint/oauth2/token
BLUEVERSE_CHAT_URL=https://blueverse-foundry.ltimindtree.com/api/v1/chat
BLUEVERSE_CLIENT_ID=your_client_id
BLUEVERSE_CLIENT_SECRET=your_client_secret
BLUEVERSE_VERIFY_SSL=true

# Agent identifier — find this in Blueverse Foundry under your agent settings
# AGENT_ID   : unique ID assigned to your agent (e.g. abc-123-def-456)
# AGENT_NAME : name of your agent (e.g. employee-policy-assistant)
# Both are sent in the request body so Blueverse knows which agent to call
# From the Blueverse agent API curl command:
#   "flowId"     = your agent's flow ID
#   "space_name" = your agent's space name
# Find both on the Blueverse agent page → API section
BLUEVERSE_AGENT_ID=your_flowId_here       # sent as "flowId" in request
BLUEVERSE_AGENT_NAME=your_space_name_here # sent as "space_name" in request

# Blueverse API uses "query" as the request field (not "message")
# Adjust RESPONSE_FIELD based on what Blueverse returns
BLUEVERSE_REQUEST_FIELD=query
BLUEVERSE_RESPONSE_FIELD=response

# Optional: manual description of what the agent covers
# Used as fallback if auto-probing the agent fails
# If not set, system will probe the agent automatically
BLUEVERSE_DESCRIPTION=LTIMindtree employee policy assistant covering annual leave, remote work policy, code of conduct, employee benefits, performance review and expense reimbursement


# -------------------------------------------------------------
# MCP SERVER
# Only needed if registering MCP server with Blueverse Foundry
# Run: python mcp_server.py
# Expose: ngrok http 8502
# Register ngrok URL in Blueverse as MCP tool server
# -------------------------------------------------------------
MCP_SERVER_PORT=8502


# -------------------------------------------------------------
# SCHEDULING
# How often the orchestrator fires automatically
# (Not used when clicking buttons manually in the dashboard)
# -------------------------------------------------------------
TRIGGER_INTERVAL_SECONDS=120

# How many questions to fire per cycle (parallel)
QUESTIONS_PER_CYCLE=3
