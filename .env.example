# Choose provider: "azure", "groq", or "grok"
LLM_PROVIDER=azure

# --- Azure OpenAI (PRIMARY - recommended, no rate limits) ---
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Groq (free tier fallback - has rate limits) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Grok / xAI (alternative) ---
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-3

# RAG App URL (where test agent sends questions)
RAG_APP_URL=http://localhost:8000

# Trigger interval in seconds (120 = 2 minutes)
TRIGGER_INTERVAL_SECONDS=120
