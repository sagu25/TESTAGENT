# Choose provider: "azure", "groq", or "grok"
LLM_PROVIDER=azure

# --- Azure OpenAI (PRIMARY - recommended, no rate limits) ---
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Groq (free tier fallback - has rate limits) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Grok / xAI (alternative) ---
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-3

# RAG App URL — use "blueverse" to test Blueverse agent
RAG_APP_URL=http://localhost:8000
# RAG_APP_URL=blueverse

# --- Blueverse Foundry Agent ---
BLUEVERSE_TOKEN_URL=https://your-token-endpoint/oauth/token
BLUEVERSE_CHAT_URL=https://blueverse-foundry.ltimindtree.com/api/v1/chat
BLUEVERSE_CLIENT_ID=your_client_id
BLUEVERSE_CLIENT_SECRET=your_client_secret
BLUEVERSE_VERIFY_SSL=true
BLUEVERSE_DESCRIPTION=LTIMindtree employee policy assistant covering annual leave, remote work, benefits, code of conduct, performance review and expense reimbursement
BLUEVERSE_REQUEST_FIELD=message
BLUEVERSE_RESPONSE_FIELD=response

# MCP Server port (for Blueverse to connect to)
MCP_SERVER_PORT=8502

# Trigger interval in seconds (120 = 2 minutes)
TRIGGER_INTERVAL_SECONDS=120
